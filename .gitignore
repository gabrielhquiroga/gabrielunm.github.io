# ============================================
# Gabriel H. Quiroga — Portfolio .gitignore
# ============================================

# --- Context & Documentation (private, not tracked) ---
context/

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor directories and files ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
.factorypath
*.sublime-project
*.sublime-workspace

# --- Node modules (if added later) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build & dist ---
dist/
build/
*.log

# --- Environment variables ---
.env
.env.local
.env.*.local

# --- Temporary files ---
*.tmp
*.temp
.cache/

# --- Package manager files (if not needed) ---
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Backup files ---
*.bak
*.backup
*.old
